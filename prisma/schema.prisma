// Sophia Database Schema
// Versión: 2.0.0
// PostgreSQL (Neon) + NextAuth v5 (JWT strategy)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 1. AUTENTICACIÓN Y USUARIOS
// ============================================

enum UserRole {
  STUDENT
  INSTRUCTOR
  ADMIN
  SUPERADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  image         String?
  googleId      String?   @unique
  avatar        String?
  role          UserRole  @default(STUDENT)
  careerId      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relaciones
  career             Career?              @relation(fields: [careerId], references: [id])
  lessonSessions     LessonSession[]
  accounts           Account[]
  courses            Course[]
  sectionInstructors SectionInstructor[]
  enrollments        Enrollment[]
  assessmentsCreated Assessment[]

  @@index([email])
  @@index([googleId])
  @@index([careerId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  // Relaciones
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ============================================
// 2. CARRERAS / PROGRAMAS
// ============================================

model Career {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  // Relaciones
  users   User[]
  courses Course[]
}

// ============================================
// 3. CONTENIDO EDUCATIVO
// ============================================

enum CourseMethodology {
  REFLECTIVE // Actividades + verificación socrática (default)
  CODE       // Instrucciones paso a paso + verificación binaria
}

model Course {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  capacidad   String?  @db.Text  // Competencia general del curso
  instructor  String   @db.Text  // Personalidad del AI instructor
  userId      String?            // Instructor que creó el curso
  careerId    String?            // Carrera a la que pertenece el curso
  voiceEnabled Boolean @default(true)  // Si false, el chat del curso oculta el botón de voz
  // Metodología pedagógica del curso (todas sus lecciones la heredan):
  //  - REFLECTIVE: actividades con prompt de instrucción + verificación socrática (default actual)
  //  - CODE: instrucciones paso a paso, verificación binaria (hizo/no hizo), sin rúbrica de comprensión
  methodology     CourseMethodology @default(REFLECTIVE)
  allowPaste      Boolean @default(false)  // Permitir pegar texto en el chat del estudiante
  allowImagePaste Boolean @default(false)  // Permitir pegar/adjuntar imágenes en el chat del estudiante
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relaciones
  user     User?     @relation(fields: [userId], references: [id])
  career   Career?   @relation(fields: [careerId], references: [id])
  lessons  Lesson[]
  sections Section[]

  @@index([slug])
  @@index([userId])
  @@index([careerId])
  @@index([deletedAt])
}

model Lesson {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  objective   String   // Objetivo de la lección
  keyPoints   String[] // Puntos clave de la lección
  contentJson Json     // { moments: [...] }
  videoUrl    String?   // URL del video animado de Sophia (panel lateral durante la clase)
  order       Int       @default(0)
  isPublished      Boolean   @default(false)
  availableAt      DateTime? // Fecha/hora desde la cual está disponible para estudiantes
  closesAfterHours Int       @default(3) // Horas después de availableAt para cerrar la sesión
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relaciones
  courseId          String
  course            Course                  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  sessions          LessonSession[]
  sectionSchedules  SectionLessonSchedule[]
  assessments       Assessment[]
  translations      LessonContentTranslation[]

  @@index([slug])
  @@index([courseId])
}

/**
 * Cache de traducción del contenido estático de una lección (title, objective,
 * keyPoints, descripciones de imágenes). Se llena lazy: la primera vez que un
 * visitante del kiosko elige EN para una lección, Haiku traduce y se guarda.
 * Próximas veces se lee del cache — costo ~$0.001 por lección, una sola vez.
 *
 * NO incluye el contenido de las actividades (agent_instruction, must_include,
 * verification.question). Esos se quedan en español como single source of
 * truth — Claude los traduce on-the-fly via system prompt en cada respuesta.
 */
model LessonContentTranslation {
  id                String   @id @default(cuid())
  lessonId          String
  language          Language
  title             String
  objective         String   @db.Text
  keyPoints         String[]
  imageDescriptions Json     @default("[]") // [{ url, description }]
  generatedAt       DateTime @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, language])
  @@index([lessonId])
}

// ============================================
// 3. APRENDIZAJE
// ============================================

enum Language {
  ES // Español (default)
  EN // English (kiosko internacional / ferias)
}

model LessonSession {
  id             String    @id @default(cuid())
  userId         String
  lessonId       String
  enrolledAt     DateTime  @default(now())
  sessionAttempt Int       @default(1)
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  lastActivityAt DateTime  @default(now())
  activityId     String?   // Referencia a contentJson.activities[].id
  summaryText    String?   @db.Text
  lastSummaryAt  DateTime?
  // Propuesta de proyecto acordada con el estudiante en la sesión-bisagra
  // (cursos de metodología CODE basados en proyecto personal del estudiante).
  // Una vez fijada, se inyecta como contexto en las actividades posteriores.
  projectBrief   Json?
  isTest         Boolean   @default(false)
  sectionId      String?   // Snapshot de la sección al iniciar sesión
  progress       Float     @default(0)
  grade          Float?
  completedAt    DateTime?
  passed         Boolean   @default(false)
  // Idioma de la sesión. En kiosko se setea en el registro (toggle ES/EN).
  // En /learn queda ES por default. Se pasa al system prompt de Claude y
  // al TTS para que Sophia responda en el idioma elegido.
  language       Language  @default(ES)

  // Relaciones
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson     Lesson             @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  messages   Message[]
  activities ActivityProgress[]
  assessmentParticipant AssessmentParticipant?
  survey     LessonSurvey?

  @@unique([userId, lessonId, sessionAttempt])
  @@index([userId])
  @@index([lessonId])
  @@index([sectionId])
}

// ============================================
// 3.5 ENCUESTA NPS POST-LECCIÓN
// ============================================

enum SurveyUtility {
  VERY_USEFUL    // "Muy útil — voy a usarlo"
  USEFUL         // "Útil — algo me va a servir"
  LOW_USEFUL     // "Poco útil — no sé cuándo lo usaré"
  NOT_USEFUL     // "Nada útil — no me sirve"
}

model LessonSurvey {
  id          String        @id @default(cuid())
  sessionId   String        @unique  // 1 encuesta por sesión, sin duplicados
  npsScore    Int                    // 1-10 (variante sin 0)
  npsReason   String?       @db.Text // texto libre opcional, max ~300 chars
  utility     SurveyUtility          // self-reported utilidad práctica
  language    Language      @default(ES) // Idioma en que se respondió la encuesta
  submittedAt DateTime      @default(now())

  session LessonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([npsScore])
  @@index([submittedAt])
}

enum ActivityStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  NEEDS_REVIEW
}

model ActivityProgress {
  id              String         @id @default(cuid())
  lessonSessionId String
  activityId      String         // Referencia a contentJson.activities[].id
  status          ActivityStatus @default(NOT_STARTED)
  startedAt       DateTime?
  completedAt     DateTime?
  evidenceData    Json?
  verifiedBy      String?
  passedCriteria  Boolean        @default(false)
  aiFeedback      String?        @db.Text
  attempts        Int            @default(0)
  tangentCount    Int            @default(0) // Track off-topic question count

  // Relaciones
  lessonSession LessonSession @relation(fields: [lessonSessionId], references: [id], onDelete: Cascade)

  @@unique([lessonSessionId, activityId])
  @@index([lessonSessionId])
  @@index([status])
}

model Message {
  id           String   @id @default(cuid())
  sessionId    String
  role         String
  content      String   @db.Text
  timestamp    DateTime @default(now())
  activityId   String?  // Referencia a contentJson.activities[].id
  inputTokens  Int?
  outputTokens Int?

  // Relaciones
  session LessonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
}

// ============================================
// 4. PERIODOS ACADÉMICOS Y SECCIONES
// ============================================

model AcademicPeriod {
  id        String   @id @default(cuid())
  name      String   @unique // "2025-1", "2025-2", "2026-1"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  sections Section[]
}

model Section {
  id        String   @id @default(cuid())
  name      String   // "Salón A", "Salón B"
  courseId   String
  periodId  String
  createdAt DateTime @default(now())

  course      Course                  @relation(fields: [courseId], references: [id])
  period      AcademicPeriod          @relation(fields: [periodId], references: [id])
  instructors SectionInstructor[]
  enrollments Enrollment[]
  schedules   SectionLessonSchedule[]

  @@unique([courseId, periodId, name])
  @@index([courseId])
  @@index([periodId])
}

model SectionInstructor {
  id        String   @id @default(cuid())
  userId    String
  sectionId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([userId, sectionId])
  @@index([userId])
  @@index([sectionId])
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  sectionId  String
  enrolledAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  section Section @relation(fields: [sectionId], references: [id])

  @@unique([userId, sectionId])
  @@index([userId])
  @@index([sectionId])
}

model SectionLessonSchedule {
  id               String    @id @default(cuid())
  sectionId        String
  lessonId         String
  availableAt      DateTime?
  closesAfterHours Int       @default(3)

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  lesson  Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([sectionId, lessonId])
  @@index([sectionId])
  @@index([lessonId])
}

// ============================================
// 5. EVALUACIONES ANÓNIMAS (MODO EVENTO/KIOSKO)
// ============================================

model Assessment {
  id              String    @id @default(cuid())
  code            String    @unique  // Código corto único: "AB12CD"
  title           String
  lessonId        String
  createdById     String              // Admin que la creó (Paola)
  isActive        Boolean   @default(true)
  timeLimitMin    Int       @default(10)  // Minutos por participante
  collectEmail    Boolean   @default(false) // Solicitar email opcional
  collectDni      Boolean   @default(true)  // Solicitar DNI
  createdAt       DateTime  @default(now())
  closedAt        DateTime?
  expiresAt       DateTime? // Cuándo se borran los datos temporales

  lesson       Lesson                  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  createdBy    User                    @relation(fields: [createdById], references: [id])
  participants AssessmentParticipant[]

  @@index([code])
  @@index([createdById])
}

model AssessmentParticipant {
  id              String    @id @default(cuid())
  assessmentId    String
  firstName       String
  lastName        String?
  dni             String?
  email           String?
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  grade           Float?    // 0-100, después se convierte a 0-20
  gradeOver20     Float?    // Nota final sobre 20
  passed          Boolean   @default(false)
  sessionId       String?   @unique // Link to the LessonSession of this participant
  language        Language  @default(ES) // Idioma elegido en el toggle del registro

  assessment Assessment    @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  session    LessonSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  // Nota: NO ponemos @@unique([assessmentId, dni]) porque hay datos legacy
  // con DNIs duplicados de antes del feature de recovery. La unicidad se
  // enforce en código (lib /api/eval/[code]/start) — si el DNI ya existe,
  // se reusa el participant en vez de crear uno nuevo.
  @@index([assessmentId])
  @@index([assessmentId, dni]) // index no-único para búsqueda rápida en recovery
}
