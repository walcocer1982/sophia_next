// Sophia Database Schema
// Versión: 2.0.0
// PostgreSQL (Neon) + NextAuth v5 (JWT strategy)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 1. AUTENTICACIÓN Y USUARIOS
// ============================================

enum UserRole {
  STUDENT
  INSTRUCTOR
  ADMIN
  SUPERADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  image         String?
  googleId      String?   @unique
  avatar        String?
  role          UserRole  @default(STUDENT)
  careerId      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relaciones
  career             Career?              @relation(fields: [careerId], references: [id])
  lessonSessions     LessonSession[]
  accounts           Account[]
  courses            Course[]
  sectionInstructors SectionInstructor[]
  enrollments        Enrollment[]
  assessmentsCreated Assessment[]

  @@index([email])
  @@index([googleId])
  @@index([careerId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  // Relaciones
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ============================================
// 2. CARRERAS / PROGRAMAS
// ============================================

model Career {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  // Relaciones
  users   User[]
  courses Course[]
}

// ============================================
// 3. CONTENIDO EDUCATIVO
// ============================================

model Course {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  capacidad   String?  @db.Text  // Competencia general del curso
  instructor  String   @db.Text  // Personalidad del AI instructor
  userId      String?            // Instructor que creó el curso
  careerId    String?            // Carrera a la que pertenece el curso
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relaciones
  user     User?     @relation(fields: [userId], references: [id])
  career   Career?   @relation(fields: [careerId], references: [id])
  lessons  Lesson[]
  sections Section[]

  @@index([slug])
  @@index([userId])
  @@index([careerId])
  @@index([deletedAt])
}

model Lesson {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  objective   String   // Objetivo de la lección
  keyPoints   String[] // Puntos clave de la lección
  contentJson Json     // { moments: [...] }
  order       Int       @default(0)
  isPublished      Boolean   @default(false)
  availableAt      DateTime? // Fecha/hora desde la cual está disponible para estudiantes
  closesAfterHours Int       @default(3) // Horas después de availableAt para cerrar la sesión
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relaciones
  courseId          String
  course            Course                  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  sessions          LessonSession[]
  sectionSchedules  SectionLessonSchedule[]
  assessments       Assessment[]

  @@index([slug])
  @@index([courseId])
}

// ============================================
// 3. APRENDIZAJE
// ============================================

model LessonSession {
  id             String    @id @default(cuid())
  userId         String
  lessonId       String
  enrolledAt     DateTime  @default(now())
  sessionAttempt Int       @default(1)
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  lastActivityAt DateTime  @default(now())
  activityId     String?   // Referencia a contentJson.activities[].id
  summaryText    String?   @db.Text
  lastSummaryAt  DateTime?
  isTest         Boolean   @default(false)
  sectionId      String?   // Snapshot de la sección al iniciar sesión
  progress       Float     @default(0)
  grade          Float?
  completedAt    DateTime?
  passed         Boolean   @default(false)

  // Relaciones
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson     Lesson             @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  messages   Message[]
  activities ActivityProgress[]
  assessmentParticipant AssessmentParticipant?

  @@unique([userId, lessonId, sessionAttempt])
  @@index([userId])
  @@index([lessonId])
  @@index([sectionId])
}

enum ActivityStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  NEEDS_REVIEW
}

model ActivityProgress {
  id              String         @id @default(cuid())
  lessonSessionId String
  activityId      String         // Referencia a contentJson.activities[].id
  status          ActivityStatus @default(NOT_STARTED)
  startedAt       DateTime?
  completedAt     DateTime?
  evidenceData    Json?
  verifiedBy      String?
  passedCriteria  Boolean        @default(false)
  aiFeedback      String?        @db.Text
  attempts        Int            @default(0)
  tangentCount    Int            @default(0) // Track off-topic question count

  // Relaciones
  lessonSession LessonSession @relation(fields: [lessonSessionId], references: [id], onDelete: Cascade)

  @@unique([lessonSessionId, activityId])
  @@index([lessonSessionId])
  @@index([status])
}

model Message {
  id           String   @id @default(cuid())
  sessionId    String
  role         String
  content      String   @db.Text
  timestamp    DateTime @default(now())
  activityId   String?  // Referencia a contentJson.activities[].id
  inputTokens  Int?
  outputTokens Int?

  // Relaciones
  session LessonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
}

// ============================================
// 4. PERIODOS ACADÉMICOS Y SECCIONES
// ============================================

model AcademicPeriod {
  id        String   @id @default(cuid())
  name      String   @unique // "2025-1", "2025-2", "2026-1"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  sections Section[]
}

model Section {
  id        String   @id @default(cuid())
  name      String   // "Salón A", "Salón B"
  courseId   String
  periodId  String
  createdAt DateTime @default(now())

  course      Course                  @relation(fields: [courseId], references: [id])
  period      AcademicPeriod          @relation(fields: [periodId], references: [id])
  instructors SectionInstructor[]
  enrollments Enrollment[]
  schedules   SectionLessonSchedule[]

  @@unique([courseId, periodId, name])
  @@index([courseId])
  @@index([periodId])
}

model SectionInstructor {
  id        String   @id @default(cuid())
  userId    String
  sectionId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([userId, sectionId])
  @@index([userId])
  @@index([sectionId])
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  sectionId  String
  enrolledAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  section Section @relation(fields: [sectionId], references: [id])

  @@unique([userId, sectionId])
  @@index([userId])
  @@index([sectionId])
}

model SectionLessonSchedule {
  id               String    @id @default(cuid())
  sectionId        String
  lessonId         String
  availableAt      DateTime?
  closesAfterHours Int       @default(3)

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  lesson  Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([sectionId, lessonId])
  @@index([sectionId])
  @@index([lessonId])
}

// ============================================
// 5. EVALUACIONES ANÓNIMAS (MODO EVENTO/KIOSKO)
// ============================================

model Assessment {
  id              String    @id @default(cuid())
  code            String    @unique  // Código corto único: "AB12CD"
  title           String
  lessonId        String
  createdById     String              // Admin que la creó (Paola)
  isActive        Boolean   @default(true)
  timeLimitMin    Int       @default(10)  // Minutos por participante
  collectEmail    Boolean   @default(false) // Solicitar email opcional
  collectDni      Boolean   @default(true)  // Solicitar DNI
  createdAt       DateTime  @default(now())
  closedAt        DateTime?
  expiresAt       DateTime? // Cuándo se borran los datos temporales

  lesson       Lesson                  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  createdBy    User                    @relation(fields: [createdById], references: [id])
  participants AssessmentParticipant[]

  @@index([code])
  @@index([createdById])
}

model AssessmentParticipant {
  id              String    @id @default(cuid())
  assessmentId    String
  firstName       String
  lastName        String
  dni             String?
  email           String?
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  grade           Float?    // 0-100, después se convierte a 0-20
  gradeOver20     Float?    // Nota final sobre 20
  passed          Boolean   @default(false)
  sessionId       String?   @unique // Link to the LessonSession of this participant

  assessment Assessment    @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  session    LessonSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([assessmentId])
}
